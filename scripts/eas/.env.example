# Celo EAS Attestation Config
# Copy to .env and fill in values

# Wallet private key (hex, no 0x prefix)
PRIVATE_KEY=

# Celo RPC (default: public Forno endpoint)
CELO_RPC_URL=https://forno.celo.org

# KOI API base URL for fetching proof packs (can be localhost via SSH tunnel)
KOI_API_BASE_URL=http://45.132.245.30:8351

# Public URL for proof pack URIs stored on-chain (defaults to KOI_API_BASE_URL if unset)
KOI_PUBLIC_URL=http://45.132.245.30:8351

# EAS Schema UID (populated after first schema registration)
EAS_SCHEMA_UID=
