  "uiHints": {
    "apiEndpoint": { "label": "KOI API Endpoint" },
    "vaultPath": { "label": "Vault Path" },
    "crawlTokenTelegram": { "label": "Crawl Token (Telegram)", "sensitive": true },
    "crawlSecretTelegram": { "label": "Crawl Secret (Telegram)", "sensitive": true }
  }
}
